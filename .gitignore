# Generated build artifacts — run `python build.py` to regenerate from data.py + sources.py
index.html
dist/
_app_check.js

# Node / Playwright
node_modules/
test-results/
playwright-report/
/playwright/.cache/

# Python
__pycache__/
*.pyc

# Scratch temp files (research provenance in scratch/research/ IS tracked)
scratch/*.png
scratch/*.py
scratch/*.js
scratch/*.output

# Bundles / archives
*.zip

# Machine-local Claude Code settings
.claude/settings.local.json

# graphify generated artifacts (only docs/analysis/graph/GRAPH_REPORT.md is versioned)
graphify-out/
docs/graphify-out/

# graphify writes graphify-out/ relative to CWD; a subagent running it from a subfolder
# creates a stray cache tree. Ignore it anywhere, not just at the root.
**/graphify-out/
